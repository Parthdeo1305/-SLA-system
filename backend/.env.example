# ─────────────────────────────────────────
# Shipment Tracking System — Backend .env
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/shipment_tracker
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/shipment_tracker

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRE=7d

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000
